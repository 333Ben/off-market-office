# Copy this file to .env and fill in what you have.
# The app boots and demos fully with only PROVIDERS=mock (no keys required).
# Add ANTHROPIC_API_KEY to get real Claude-written scoring, matches, and cadences.

ANTHROPIC_API_KEY=
FULLENRICH_API_KEY=
SILLAGE_API_KEY=

# mock (default, offline-safe) | fullenrich | sillage | bodacc
PROVIDERS=mock

# Optional overrides
# PORT=3001
# ANTHROPIC_MODEL=claude-sonnet-4-6
